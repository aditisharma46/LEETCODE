class Solution:
    def countSubmatrices(self, grid: List[List[int]], k: int) -> int:
        n = len(grid[0])
        col_sums = [0]*n
        ans = 0
        
        for row in grid:
            running_sum = 0
            for j in range(n):
                running_sum += row[j]
                col_sums[j] += running_sum

                if col_sums[j] <= k:
                    ans += 1
                else:
                    break
        return ans
        
